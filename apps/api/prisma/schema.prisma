// Responsibility:
// Defines the database structure for the Zionra API.
//
// This schema supports password authentication, Google authentication,
// email verification, password reset, and database-backed rolling sessions.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CustomerStatus {
  ACTIVE
  SUSPENDED
}

enum OAuthProvider {
  GOOGLE
}

model Customer {
  id                 String         @id @default(cuid())
  firstName          String
  lastName           String
  email              String         @unique
  phoneCountryCode   String
  phoneNumber        String
  passwordHash       String?
  countryOfResidence String
  referralSource     String?
  acceptedTermsAt    DateTime
  marketingOptIn     Boolean        @default(false)
  emailVerifiedAt    DateTime?
  status             CustomerStatus @default(ACTIVE)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  emailVerificationCodes CustomerEmailVerificationCode[]
  passwordResetCodes          CustomerPasswordResetCode[]
  passwordResetAuthorizations CustomerPasswordResetAuthorization[]
  sessions                    CustomerSession[]
  oauthAccounts          CustomerOAuthAccount[]

  @@index([email])
  @@index([phoneCountryCode, phoneNumber])
}

model CustomerEmailVerificationCode {
  id        String    @id @default(cuid())
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([codeHash])
}

model CustomerPasswordResetCode {
  id        String    @id @default(cuid())
  codeHash  String
  expiresAt DateTime
  usedAt         DateTime?
  failedAttempts Int       @default(0)
  createdAt      DateTime  @default(now())

  customerId   String
  customer     Customer                           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  authorization CustomerPasswordResetAuthorization?

  @@index([customerId])
  @@index([codeHash])
}

model CustomerPasswordResetAuthorization {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  passwordResetCodeId String                    @unique
  passwordResetCode   CustomerPasswordResetCode @relation(fields: [passwordResetCodeId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

model CustomerSession {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

model CustomerOAuthAccount {
  id                String        @id @default(cuid())
  provider          OAuthProvider
  providerAccountId String
  email             String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([provider, customerId])
  @@index([email])
}

model CustomerOAuthSignup {
  id                String        @id @default(cuid())
  provider          OAuthProvider
  providerAccountId String
  tokenHash         String        @unique
  email             String
  firstName         String
  lastName          String
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([provider, providerAccountId])
  @@index([email])
  @@index([expiresAt])
}
